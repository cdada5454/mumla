<se.lublin.mumla.channel.ChatKeyboardFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:ignore="NewApi">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:background="@android:color/transparent"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="72dp"
        tools:listitem="@layout/list_chat_item" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/chat_composer_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="6dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="@color/chat_composer_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="false"
        app:strokeColor="@android:color/transparent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/chatImageSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/share"
                android:enabled="false"
                app:srcCompat="@drawable/image_24"
                app:tint="?android:attr/textColorSecondary" />

            <se.lublin.mumla.channel.ChatComposerEditText
                android:id="@+id/chatTextEdit"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@null"
                android:gravity="center_vertical|start"
                android:hint="@string/send_message"
                android:imeOptions="actionSend"
                android:includeFontPadding="false"
                android:inputType="textAutoCorrect|textMultiLine"
                android:lineSpacingExtra="0dp"
                android:maxLines="4"
                android:minHeight="44dp"
                android:paddingStart="8dp"
                android:paddingTop="0dp"
                android:paddingEnd="8dp"
                android:paddingBottom="0dp"
                android:textCursorDrawable="@drawable/chat_text_cursor"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/chatTextSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/send_message"
                android:enabled="false"
                app:srcCompat="@drawable/send_24"
                app:tint="?attr/colorPrimary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</se.lublin.mumla.channel.ChatKeyboardFrameLayout>
